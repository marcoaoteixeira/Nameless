{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Resources": {
    "postgres": {
      "Image": "postgres:17.9-bookworm",
      "HostPort": 5432,
      "VolumeName": "microservice-postgres-db-volume",
      "IsPersistent": true,
      "PgAdmin": {
        "Image": "elestio/pgadmin:REL-9_14",
        "HostPort": 6543,
        "IsPersistent": true
      } 
    }
  } 
}
