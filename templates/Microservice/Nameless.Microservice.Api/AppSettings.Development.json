{
  // *** .NET ***
  "ConnectionStrings": {
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // *** Nameless ***
  "AppDataProtection": {
    "ApplicationDiscriminator": null,
    "UseFileSystem": false,
    "FileSystemPath": null
  },

  "ApplicationContext": {
    "EnvironmentName": "Development",
    "ApplicationName": "App",
    "ApplicationDataLocation": "User",
    "CustomApplicationDataDirectoryPath": "App_Data",
    "Version": "1.0.0"
  },

  "FileSystemProvider": {
    "Root": "App_Data",
    "AllowOperationOutsideRoot": false
  },

  "Workers": {
    "SampleWorker": {
      "IsDisabled": false,
      "Interval": "00:00:05" // 5 seconds
    }
  },

  "Bootstrap": {
    "EnableParallelExecution": true,
    "MaxDegreeOfParallelism": 4
  },

  "Sqlite": {
    "UseInMemory": false,
    "DatabaseFilePath": "App_Data/database.db",
    "Password": null,
    "ConnectionStringName": "sqlite"
  },

  "SqlServer": {
    "Server": "(localdb)\\MSSQLLocalDB",
    "Database": "master",
    "Username": null,
    "Password": null,
    "UseAttachedDb": false,
    "UseIntegratedSecurity": false,
    "ConnectionStringName": "sqlserver"
  },

  "Lucene": {
    "DirectoryName": "lucene"
  },

  "Mailing": {
    "Host": "localhost",
    "Port": 25,
    "Username": null,
    "Password": null,
    "SecureSocket": "None"
  },

  "RabbitMQ": null,

  "RijndaelCrypto": {
    "Passphrase": "29850952b3ef9f90",
    "Iv": "9e209040c863f84a",
    "Salt": "",
    "KeySize": "Large",
    "MinimumSaltSize": 4,
    "MaximumSaltSize": 255,
    "KeyIterationsCount": 1
  },

  "JsonWebToken": {
    "Authority": null,
    "Issuers": [],
    "ValidateIssuer": false,
    "Audiences": [],
    "ValidateAudience": false,
    "ValidateLifetime": false,
    "ValidateIssuerSigninKey": false,
    "Secret": "1480a572-2424-48a5-b0fd-53314ef3eecb",
    "SecurityAlgorithm": "HS256",
    "ClockSkew": "00:00:05"
  },

  "HttpRequestCorrelation": {
    "HeaderKey": "X-Correlation-ID",
    "IncludeInResponse": true
  },

  "CorsPolicies": {
    "AllowEverything": {
      "Headers": "*",
      "Methods": "*",
      "Origins": "*",
      "SupportsCredentials": false,
      "PreflightMaxAge": null,
      "Skip": false
    }
  },

  "OutputCachePolicies": {
    "FiveSeconds": {
      "Duration": "00:00:05",
      "Skip": false
    },
    "FifteenSeconds": {
      "Duration": "00:00:15",
      "Skip": false
    }
  },

  "RequestTimeoutPolicies": {
    "OneSecond": {
      "ExpiresIn": "00:00:01",
      "HttpStatusCode": 408,
      "Skip": false
    },
    "FiveSeconds": {
      "ExpiresIn": "00:00:05",
      "HttpStatusCode": 408,
      "Skip": false
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "App_Data/log-.txt",
          "rollingInterval": "Day",
          "rollingOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "ApplicationName": "Identity"
    }
  }
}
