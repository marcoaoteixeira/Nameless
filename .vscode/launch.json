{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Web Application (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build Web Application (Debug)",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/apps/WebApplication/Nameless.WebApplication.Web/bin/Debug/netcoreapp3.0/Nameless.WebApplication.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/apps/WebApplication/Nameless.WebApplication.Web",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url} --console",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}"
                },
                "osx": {
                    "command": "open"
                },
                "linux": {
                    "command": "xdg-open"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5000;https://localhost:5443",
                "ASPNETCORE_HTTPS_PORT": "5443"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Launch Bookshelf (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build Bookshelf (Debug)",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/apps/Bookshelf/Nameless.Bookshelf.Web/bin/Debug/netcoreapp3.1/Nameless.Bookshelf.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/apps/Bookshelf/Nameless.Bookshelf.Web",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url} --console",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}"
                },
                "osx": {
                    "command": "open"
                },
                "linux": {
                    "command": "xdg-open"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5000;https://localhost:5443",
                "ASPNETCORE_HTTPS_PORT": "5443"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }

    ]
}