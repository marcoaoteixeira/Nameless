# =============================================================================
# .claudeignore — Nameless .NET/C# Library
# =============================================================================
# Uses gitignore syntax. Claude Code will deprioritize these paths from its
# context window, saving tokens for what actually matters: source code,
# project files, tests, and configuration.
#
# NOTE: .claudeignore is a context-shaping hint, not a hard security boundary.
# For truly sensitive files (secrets, credentials), use permissions.deny in
# .claude/settings.json instead.
# =============================================================================


# -----------------------------------------------------------------------------
# Build output directories
# Intermediate and final outputs from MSBuild / dotnet CLI.
# These are ephemeral and never represent canonical source.
# -----------------------------------------------------------------------------
**/bin/
**/obj/
**/out/
**/publish/
**/artifacts/


# -----------------------------------------------------------------------------
# NuGet package artifacts
# Local packages produced during pack/publish routines.
# -----------------------------------------------------------------------------
**/*.nupkg
**/*.snupkg
**/nupkg/
**/packages-local/
# NuGet restore cache (usually in ~/.nuget but sometimes committed by mistake)
**/packages/


# -----------------------------------------------------------------------------
# Test runner outputs
# Coverage reports, trx result files, and related tooling artifacts.
# These are generated by the CI/build routine and carry no authoring intent.
# -----------------------------------------------------------------------------
**/TestResults/
**/*.trx
**/*.coverage
**/*.coveragexml
**/coverage/
**/CoverageReport/
# Coverlet / ReportGenerator outputs
**/lcov.info
**/cobertura.xml


# -----------------------------------------------------------------------------
# Auto-generated XML documentation
# Emitted by the compiler when <GenerateDocumentationFile> is true.
# The *source* XML doc comments in .cs files are the canonical input.
# -----------------------------------------------------------------------------
**/*.xml
# Exception: keep project/solution/config XML files
!**/*.csproj
!**/*.vbproj
!**/*.fsproj
!**/*.sln
!**/*Directory.Build.props
!**/*Directory.Build.targets
!**/*Directory.Packages.props
!**/*.runsettings
!**/*.editorconfig
!**/*.ruleset
!NuGet.Config
!nuget.config


# -----------------------------------------------------------------------------
# Auto-generated source code
# Outputs from Source Generators, T4 templates, or scaffolding tools.
# Adjust paths to match your solution's conventions.
# -----------------------------------------------------------------------------
**/Generated/
**/generated/
**/*.g.cs
**/*.g.i.cs
**/*.designer.cs
# T4 templates output (keep *.tt source, ignore *.cs output)
**/*.tt.cs


# -----------------------------------------------------------------------------
# Roslyn / compiler auxiliary files
# -----------------------------------------------------------------------------
**/.vs/
**/*.user
**/*.suo
**/*.userosscache
**/*.sln.docstates


# -----------------------------------------------------------------------------
# IDE and editor noise
# -----------------------------------------------------------------------------
**/.idea/
**/.vscode/
**/*.DotSettings
**/*.DotSettings.user


# -----------------------------------------------------------------------------
# Branding and media assets
# Images, icons, logos — valuable for humans, zero value for code reasoning.
# -----------------------------------------------------------------------------
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.ico
**/*.bmp
**/*.tiff
**/*.webp
**/*.psd
**/*.ai
**/*.eps
# Fonts
**/*.ttf
**/*.otf
**/*.woff
**/*.woff2


# -----------------------------------------------------------------------------
# Documentation build output
# Generated static sites from tools like DocFX, Sandcastle, or Swagger.
# The *source* markdown/XML is what matters.
# -----------------------------------------------------------------------------
**/docs/_site/
**/docs/api/
**/site/
**/_site/
**/docfx_project/api/
**/docfx_project/obj/
# OpenAPI / Swagger generated clients (keep the spec itself)
**/swagger-client/
**/openapi-client/


# -----------------------------------------------------------------------------
# Logs and diagnostic output
# -----------------------------------------------------------------------------
**/*.log
**/*.log.*
**/logs/
**/Logs/


# -----------------------------------------------------------------------------
# CI/CD pipeline caches and temporaries
# Artefacts left by GitHub Actions, Azure Pipelines, etc.
# -----------------------------------------------------------------------------
**/.github/workflows/cache/
**/.azuredevops/
**/drop/
**/staging/


# -----------------------------------------------------------------------------
# Dependency lock files and restore state
# Large, machine-generated, rarely useful as context.
# -----------------------------------------------------------------------------
**/packages.lock.json
**/project.assets.json
**/project.nuget.cache
**/.packages/


# -----------------------------------------------------------------------------
# Misc temporary and OS artefacts
# -----------------------------------------------------------------------------
**/.DS_Store
**/Thumbs.db
**/*.tmp
**/*.temp
**/*.bak
**/*.orig
**/*.cache
