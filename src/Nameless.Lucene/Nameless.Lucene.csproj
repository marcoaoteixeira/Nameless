<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Title>Nameless Lucene Library</Title>
		<Description>
			Lucene.NET Abstractions Implementation provides the concrete
			implementation for the Lucene.NET Abstractions library, delivering
			a ready-to-use integration with Lucene.NET.

			It implements the defined interfaces and contracts, handling index
			creation, document insertion and updates, deletion, and search
			operations using Lucene.NET under the hood. This package allows
			you to plug in a fully functional search engine while keeping your
			application clean, testable, and decoupled from Lucene-specific
			details.
		</Description>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Lucene.Net.Analysis.Common" />
		<PackageReference Include="Lucene.Net.QueryParser" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="README.md">
			<PackagePath>\</PackagePath>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Pack>True</Pack>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Nameless.Core\Nameless.Core.csproj" />
		<ProjectReference Include="..\Nameless.Lucene.Abstractions\Nameless.Lucene.Abstractions.csproj" />
	</ItemGroup>

</Project>
