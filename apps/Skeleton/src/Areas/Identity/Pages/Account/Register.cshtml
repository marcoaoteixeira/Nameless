@page
@model RegisterPageModel
@inject IViewLocalizer T
@{
    Layout = "/Views/Shared/_Blank.cshtml";
    ViewData["Title"] = T["Register User"];
    ViewBag.PageSpecificCssClass = "register-page";
}

<div class="register-box">
    <div class="register-logo">
        <a asp-area="" asp-controller="Home" asp-action="Index"><b>Skeleton</b></a>
    </div>

    <div class="card">
        <div class="card-body register-card-body">
            <p class="login-box-msg">@T["Register a new membership"]</p>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="input-group mb-3">
                    <input asp-for="Input.UserName" class="form-control" placeholder="@T["Full name"]">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-user"></span>
                        </div>
                    </div>
                    <span asp-validation-for="Input.UserName" class="error"></span>
                </div>
                
                <div class="input-group mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="@T["E-mail"]">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-envelope"></span>
                        </div>
                    </div>
                    <span asp-validation-for="Input.Email" class="error"></span>
                </div>
                
                <div class="input-group mb-3">
                    <input asp-for="Input.Password" class="form-control" placeholder="@T["Password"]">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-lock"></span>
                        </div>
                    </div>
                    <span asp-validation-for="Input.Password" class="error"></span>
                </div>
                
                <div class="input-group mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="@T["Retype password"]">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-lock"></span>
                        </div>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="error"></span>
                </div>
                
                <div class="row">
                    <div class="col-8">
                        <div class="icheck-primary">
                            <input asp-for="Input.TermsAgreement">
                            <label asp-for="Input.TermsAgreement">
                                @T["I agree to the"] <a href="#">@T["terms"]</a>
                            </label>
                        </div>
                    </div>
                    <!-- /.col -->
                    <div class="col-4">
                        <button type="submit" class="btn btn-primary btn-block">@T["Register"]</button>
                    </div>
                    <!-- /.col -->
                </div>
            </form>

            <partial name="_SocialAuthLinks" />

            <a asp-page="./SignIn" class="text-center">@T["I already have a membership"]</a>
        </div>
        <!-- /.form-box -->
    </div><!-- /.card -->
</div>
<!-- /.register-box -->

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}