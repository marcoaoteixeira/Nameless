@page
@inject IViewLocalizer T
@{
    Layout = "/Views/Shared/_Blank.cshtml";
    ViewData["Title"] = T["E-mail Confirmation"];
    ViewBag.PageSpecificCssClass = "login-page";
}

<div>
    <div class="login-logo">
        <a asp-area="" asp-controller="Home" asp-action="Index"><b>Skeleton</b></a>
    </div>
    <!-- /.login-logo -->
    <div class="card">
        <div class="card-body">
            <div class="callout callout-success">
                <h5>@T["Thank you for confirming your email."]</h5>

                <p>@T["You may now login into the application."]</p>
            </div>

            <p class="mt-3 mb-1">
                <a asp-page="./SignIn">Login</a>
            </p>
        </div>
        <!-- /.login-card-body -->
    </div>
</div>
<!-- /.login-box -->