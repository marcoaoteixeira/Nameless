@page
@model SignOutPageModel
@inject IViewLocalizer T
@{
    Layout = "/Views/Shared/_Blank.cshtml";
    ViewData["Title"] = T["Sign Out"];
    ViewBag.PageSpecificCssClass = "lockscreen";
}

<!-- Automatic element centering -->
<div class="lockscreen-wrapper">
    <div class="lockscreen-logo">
        <a asp-area="" asp-controller="Home" asp-action="Index"><b>Skeleton</b></a>
    </div>

    </div>
    
    <!-- /.lockscreen-item -->
    <div class="help-block text-center">
        <h4>@T["You have successfully sign out of your session."]</h4>
    </div>
    
    <div class="text-center">
        <a asp-page="./SignIn">Sign in as a different user</a>
    </div>

    <div class="lockscreen-footer text-center">
        MIT 2020 <b><a href="http://github.com/marcoaoteixeira/skeleton" class="text-black">Skeleton</a></b><br>
    </div>
</div>
<!-- /.center -->