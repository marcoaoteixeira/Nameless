{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "FileProviderSettings": {},
  "FileStorageSettings": {},
  "LocalizationSettings": {
    "ResourcesBaseFolder": "Resources/i18n",
    "DefaultCultureName": "en-US",
    "Watch": false
  },
  "LoggingSettings": {
    "ConfigurationFileName": "log4net.config",
    "RepositoryName": null,
    "Watch": true
  },
  "SmtpClientSettings": {
    "Host": "localhost",
    "UsePort": true,
    "Port": 25,
    "UseCredentials": false,
    "UserName": null,
    "Password": null,
