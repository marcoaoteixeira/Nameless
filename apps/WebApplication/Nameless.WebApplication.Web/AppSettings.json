    "DeliveryMethod": "PickupDirectory"
  },
  "NHibernateSettings": {
    "DbSchemaName": "dbo",
    "TablePrefix": null,
    "Dialect": "NHibernate.Dialect.SQLiteDialect,NHibernate",
    "Driver": "NHibernate.Driver.SQLite20Driver,NHibernate",
    "KeywordsAutoImport": "auto-quote",
